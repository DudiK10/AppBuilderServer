# Copy to .env and fill in real values (never commit .env)

PORT=3000

# ── URLs ──────────────────────────────────────────────────────────────────────

# Backend PHP API base URL, no trailing slash.
# Also used to derive SERVER_BASE_URL when SERVER_BASE_URL is not explicitly set.
PHP_API_BASE=https://manageapp.in/api

# Public base URL of THIS Node.js server — REQUIRED when the builder runs on its
# own subdomain (e.g. builder.manageapp.in) separate from the PHP API.
# Logo URLs stored in the DB will use this base, so the Expo app can fetch them
# cross-domain.  Must be the domain nginx proxies to this Node.js process.
SERVER_BASE_URL=https://builder.manageapp.in

# Expo web preview URL — the subdomain/path serving the compiled Expo web build.
# Used for the live phone preview iframe in the dashboard.
PREVIEW_URL=https://preview.manageapp.in

# ── Auth ──────────────────────────────────────────────────────────────────────

JWT_SECRET=change-me-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ── Bearer token for admin API calls (same as your PHP admin token) ───────────
ADMIN_API_TOKEN=

# ── Optional: path to local Expo project if not ./expo-app ───────────────────
# EXPO_PROJECT_PATH=
